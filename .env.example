# --- Polymarket / CLOB ---
# Required only when live trading is enabled. Use a dedicated wallet.
POLY_PRIVATE_KEY=
POLY_FUNDER_ADDRESS=
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
POLY_CHAIN_ID=137
POLY_HOST=https://clob.polymarket.com

# --- External data ---
FRED_API_KEY=

# --- Ollama ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_NEWS_MODEL=llama3:8b-instruct-q8_0

# --- Nexo branding / localisation ---
# Primary display language for dashboard + logs. es | en.
NEXO_LANG=es
# URL the footer attribution links to. Override in deployment.
NEXO_BRAND_URL=https://nexoacademy.com

# --- Dashboard ---
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000

# --- Misc ---
LOG_LEVEL=INFO
